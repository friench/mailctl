{
  "name": "mailserver-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing the mail-api control plane (send, domains, mailboxes, aliases, DKIM, sync) as tools",
  "private": true,
  "type": "module",
  "bin": {
    "mailserver-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
