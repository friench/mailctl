# Dokploy stack `.env` — copy into Dokploy's environment editor for the
# Compose application that uses `docker-compose.dokploy.yml`.
#
# This file is consumed by BOTH services in the stack:
#   - mailserver: reads docker-mailserver vars (MAIL_HOSTNAME, ENABLE_*, ...)
#   - mail-api: reads SESSION_SECRET and INITIAL_ADMIN_*
# Plus Traefik wiring vars referenced from docker-compose.dokploy.yml.

# ============================================================================
# Hostnames (must already have A records pointing to the server)
# ============================================================================
# Mail server FQDN — appears in HELO, MX records, PTR, DKIM TXT, TLS cert SAN.
# Pick ONE — all other domains in your tenant just point their MX here.
MAIL_HOSTNAME=mail.example.com

# Admin dashboard hostname — Traefik routes https://${ADMIN_HOSTNAME}/admin/
# to mail-api. Use a different subdomain than MAIL_HOSTNAME.
ADMIN_HOSTNAME=mail-admin.example.com

# Note: OVERRIDE_HOSTNAME and SSL_DOMAIN are auto-derived from MAIL_HOSTNAME
# in docker-compose.dokploy.yml — you don't set them here.

# Postmaster address (RFC 5321 §4.5.1 requires this mailbox to exist).
POSTMASTER_ADDRESS=postmaster@example.com

# ============================================================================
# Traefik wiring (Dokploy ships Traefik on port 80/443)
# ============================================================================
# Network where Dokploy's Traefik is attached. Default install: dokploy-network.
# Confirm with: docker network ls | grep -i dokploy
TRAEFIK_NETWORK=dokploy-network

# Cert resolver name configured in your Traefik static config. Default Dokploy
# install names it "letsencrypt". Confirm with:
#   docker exec dokploy-traefik cat /etc/traefik/traefik.yml | grep -A2 certificatesResolvers
TRAEFIK_CERT_RESOLVER=letsencrypt

# Host path to Traefik's acme.json (Dokploy keeps it as a bind mount, NOT a
# Docker volume). The traefik-certs-dumper sidecar reads it read-only and
# extracts PEM files for docker-mailserver. Default for a fresh Dokploy
# install. If yours differs:
#   sudo find /etc/dokploy -name acme.json 2>/dev/null
#   docker inspect dokploy-traefik --format '{{range .Mounts}}{{.Source}} -> {{.Destination}}{{"\n"}}{{end}}' | grep acme
TRAEFIK_ACME_PATH=/etc/dokploy/traefik/dynamic/acme.json

# GID of the host's docker group (owner of /var/run/docker.sock). mail-api runs
# as a non-root user and needs this group to `docker exec` into the mailserver
# for mailbox/DKIM provisioning. Find it with:
#   stat -c '%g' /var/run/docker.sock
# Defaults to 983 (typical Dokploy/Debian install) if left unset.
DOCKER_GID=983

# ============================================================================
# mail-api (control plane + dashboard)
# ============================================================================
# 32+ chars, used to encrypt iron-session admin cookies. Generate once:
#   openssl rand -hex 32
SESSION_SECRET=

# Optional: bootstrap an admin user when the DB is empty (first start only).
# After first login, change the password from the dashboard.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=

LOG_LEVEL=info

# ============================================================================
# docker-mailserver — most relevant settings.
# Full reference: https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/
# ============================================================================
TZ=UTC

# TLS mode for docker-mailserver. With Traefik's acme.json mounted at
# /etc/letsencrypt, "letsencrypt" mode reads
# /etc/letsencrypt/live/${MAIL_HOSTNAME}/{fullchain,privkey}.pem.
# If your Traefik version only writes acme.json (no PEM files), switch to
# SSL_TYPE=manual and run a small extractor — see _docs/deployment.md.
# (SSL_DOMAIN is set automatically from MAIL_HOSTNAME in the compose file.)
SSL_TYPE=letsencrypt

# Account storage: FILE = /etc/dovecot/userdb (managed via the dashboard).
ACCOUNT_PROVISIONER=FILE

# Network/protocol
POSTFIX_INET_PROTOCOLS=ipv4
DOVECOT_INET_PROTOCOLS=ipv4
PERMIT_DOCKER=none
SMTP_ONLY=0
ENABLE_IMAP=1
ENABLE_POP3=0
SPOOF_PROTECTION=1

# Anti-abuse / DMARC stack
ENABLE_OPENDKIM=1
ENABLE_OPENDMARC=1
ENABLE_POLICYD_SPF=1
ENABLE_FAIL2BAN=1

# Optional anti-spam (off by default — heavy on small VPS)
ENABLE_CLAMAV=0
ENABLE_RSPAMD=0
ENABLE_SPAMASSASSIN=0

ENABLE_QUOTAS=1
POSTFIX_MESSAGE_SIZE_LIMIT=26214400

# ============================================================================
# Notes on the 4-domain setup (itpuls.ru, ipsag.ru, aladyshev.ru, alexroot.ru)
# ============================================================================
# Pick ONE host as the mail server (e.g. mail.itpuls.ru). All four domains
# get an MX record pointing to it. PTR for the server's IP also points to
# that host. The other three domains do NOT need their own A or cert — they
# are just "tenant" domains with mailboxes provisioned via the dashboard.
#
# Required DNS (per domain — SPF/DKIM/DMARC use the API's DKIM helper):
#   <domain>.                MX 10  ${MAIL_HOSTNAME}.
#   <domain>.                TXT    "v=spf1 mx -all"
#   mail._domainkey.<domain> TXT    "v=DKIM1; ..."   ← from POST /admin/api/domains/:id/dkim
#   _dmarc.<domain>.         TXT    "v=DMARC1; p=quarantine; rua=mailto:dmarc@<domain>"
#
# After adding each domain in the dashboard, click "Generate DKIM" and run
# the DNS check to confirm all five records are green.
