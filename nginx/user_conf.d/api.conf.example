# Control-plane vhost for the mail-api dashboard + REST API.
#
# Copy to `api.conf` and replace `api.example.com` with your control-plane
# hostname, then `docker compose restart nginx`. nginx only loads `*.conf`, so
# this `.example` file is inert until copied.
#
# On boot, jonasal/nginx-certbot requests a Let's Encrypt certificate for every
# `server_name` it finds (set CERTBOT_EMAIL in nginx/nginx-certbot.env). Point an
# A/AAAA record for this hostname at the server first, or the ACME http-01
# challenge on port 80 will fail. Port 80 is managed by nginx-certbot for the
# challenge; do not add an 80→443 redirect here or it can break renewals.

server {
    listen 443 ssl;
    http2 on;
    server_name api.example.com;

    ssl_certificate         /etc/letsencrypt/live/api.example.com/fullchain.pem;
    ssl_certificate_key     /etc/letsencrypt/live/api.example.com/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/api.example.com/chain.pem;

    ssl_protocols        TLSv1.2 TLSv1.3;
    ssl_session_timeout  1d;
    ssl_session_tickets  off;
    ssl_stapling         on;
    ssl_stapling_verify  on;

    add_header Strict-Transport-Security "max-age=63072000" always;
    add_header X-Content-Type-Options    nosniff              always;
    add_header X-Frame-Options           DENY                 always;
    add_header Referrer-Policy           "no-referrer"        always;

    # The /send API accepts messages up to the Postfix limit (~25 MB) plus
    # attachments; give headroom so nginx doesn't 413 before mail-api sees it.
    client_max_body_size 30m;

    location / {
        proxy_pass         http://mail-api:3050;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        # mail-api runs with TRUST_PROXY=1 and expects exactly one hop (this nginx).
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
