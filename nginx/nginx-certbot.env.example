# jonasal/nginx-certbot configuration.
# Copy to nginx-certbot.env and set at least CERTBOT_EMAIL.

# Email for Let's Encrypt registration + expiry/renewal-failure notices.
CERTBOT_EMAIL=admin@example.com

# Use the Let's Encrypt staging CA while testing to avoid hitting rate limits.
# 1 = staging (untrusted certs), 0 = production. Flip to 0 once DNS + vhosts work.
STAGING=0
