# Root .env (read by docker-compose.yml). docker-mailserver reads its config
# from here; the variables below are just the most relevant. Full list:
# https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/

# --- Mailserver hostname (must match an A record + Let's Encrypt cert) ---
MAIL_HOSTNAME=mail.example.com
OVERRIDE_HOSTNAME=mail.example.com
POSTMASTER_ADDRESS=postmaster@example.com

# --- docker-mailserver ---
TZ=UTC
ACCOUNT_PROVISIONER=FILE
SSL_TYPE=letsencrypt
PERMIT_DOCKER=none
POSTFIX_INET_PROTOCOLS=ipv4
DOVECOT_INET_PROTOCOLS=ipv4
ENABLE_IMAP=1
ENABLE_POP3=0
SMTP_ONLY=0
SPOOF_PROTECTION=1
ENABLE_OPENDKIM=1
ENABLE_OPENDMARC=1
ENABLE_POLICYD_SPF=1
ENABLE_FAIL2BAN=1
ENABLE_CLAMAV=0
ENABLE_RSPAMD=0
ENABLE_SPAMASSASSIN=0
ENABLE_QUOTAS=1
POSTFIX_MESSAGE_SIZE_LIMIT=26214400
LOG_LEVEL=info
