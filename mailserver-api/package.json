{
  "name": "mail-api",
  "version": "0.1.0",
  "description": "Generic multi-domain mail control plane for docker-mailserver",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:ui": "pnpm --dir ui dev",
    "build": "tsc -p tsconfig.build.json && pnpm --dir ui build",
    "build:api": "tsc -p tsconfig.build.json",
    "build:ui": "pnpm --dir ui build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "create-api-key": "tsx src/bin/create-api-key.ts",
    "create-admin": "tsx src/bin/create-admin.ts",
    "openapi:emit": "tsx src/bin/emit-openapi.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1077.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.4.0",
    "dockerode": "^5.0.0",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "iron-session": "^8.0.4",
    "nodemailer": "^9.0.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.4.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.0"
  }
}
