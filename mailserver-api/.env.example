# Server
NODE_ENV=development
PORT=3050
HOST=0.0.0.0
LOG_LEVEL=info

# Database (SQLite path)
DATABASE_URL=./data/data.db

# Mailbox provisioning via docker-mailserver (Phase 4)
DMS_CONTAINER_NAME=mailserver
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Per-domain nginx vhost generation (Phase 8)
NGINX_CONTAINER_NAME=nginx
NGINX_GENERATED_DIR=./data/nginx-generated
NGINX_RELOAD_ENABLED=true

# Session encryption secret (Phase 6)
# At least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Optional: bootstrap initial admin user when DB is empty
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_PASSWORD=replace-me-min-8-chars

# Path to SMTP accounts config (optional; default: ./config/accounts.json)
# CONFIG_PATH=/app/config/accounts.json

# SMTP credentials referenced by ${VAR} placeholders in accounts.json
MAIL_PASS_NOREPLY=
MAIL_USER_RELAY1=
MAIL_PASS_RELAY1=
MAIL_USER_RELAY2=
MAIL_PASS_RELAY2=

# To create the first API key after `pnpm db:migrate`, run:
#   pnpm create-api-key --name="my-app"
