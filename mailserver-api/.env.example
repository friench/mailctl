# Server
NODE_ENV=development
PORT=3050
HOST=0.0.0.0
LOG_LEVEL=info

# Database (SQLite path)
DATABASE_URL=./data/data.db

# Mailbox provisioning via docker-mailserver (Phase 4)
DMS_CONTAINER_NAME=mailserver
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Public IMAP/SMTP FQDN. Set this to enable mail-client autoconfig
# (Thunderbird / Outlook Autodiscover / Apple .mobileconfig).
# MAIL_HOSTNAME=mail.example.com

# Per-domain nginx vhost generation (Phase 8)
NGINX_CONTAINER_NAME=nginx
NGINX_GENERATED_DIR=./data/nginx-generated
NGINX_RELOAD_ENABLED=true

# Session encryption secret (Phase 6)
# At least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Send the session cookie only over HTTPS. Unset = derive from NODE_ENV
# (secure only in production). Set to true when terminating TLS at a proxy
# without running with NODE_ENV=production.
# COOKIE_SECURE=true

# Extra origins allowed to make cookie-authenticated admin mutations (CSRF
# guard). Same-origin is always allowed; set this only if the dashboard is
# served from a different host than the API. Comma-separated.
# TRUSTED_ORIGINS=https://dashboard.example.com

# Prometheus /metrics: set a token to require it, or METRICS_PUBLIC=true to
# expose without auth. Without either, /metrics 404s (fail closed).
# METRICS_TOKEN=
# METRICS_PUBLIC=false

# Optional: bootstrap initial admin user when DB is empty
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_PASSWORD=replace-me-min-8-chars

# Mailbox password policy
# PASSWORD_MIN_LENGTH=10
# Reject mailbox passwords found in the Have I Been Pwned breach corpus
# (k-anonymity: only a SHA-1 prefix is sent; fail-open on outage). Set false to disable.
# PASSWORD_HIBP_ENABLED=true

# Optional webmail URL shown as a link in the dashboard (e.g. Roundcube)
# WEBMAIL_URL=https://webmail.example.com

# Path to SMTP accounts config (optional; default: ./config/accounts.json)
# CONFIG_PATH=/app/config/accounts.json

# SMTP credentials referenced by ${VAR} placeholders in accounts.json
MAIL_PASS_NOREPLY=
MAIL_USER_RELAY1=
MAIL_PASS_RELAY1=
MAIL_USER_RELAY2=
MAIL_PASS_RELAY2=

# To create the first API key after `pnpm db:migrate`, run:
#   pnpm create-api-key --name="my-app"
